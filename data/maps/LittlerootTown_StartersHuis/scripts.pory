mapscripts LittlerootTown_StartersHuis_MapScripts{
    MAP_SCRIPT_ON_TRANSITION: LittlerootTown_StartersHuis_EventScript_BallDefault
}
 
script LittlerootTown_StartersHuis_EventScript_BallDefault{
    setvar(STARTER_LAB, 0)
}
 
script LittlerootTown_StartersHuis_EventScript_Starmans{
   if(!(flag(STARTER_GEN1) || flag(STARTER_GEN2) || flag(STARTER_GEN3) )){
    lock
    faceplayer
    message("Hello, I am Professor Starmans")
    multichoice(25, 5, MULTI_STARTER_CHOICE, 0)
    closemessage
        if(var(VAR_RESULT) == 0){
            call(StarterFade)
            setvar(STARTER_LAB, 0)
        }
        elif (var(VAR_RESULT) == 1){
            call(StarterFade)
            setvar(STARTER_LAB, 1)
        }
        elif (var(VAR_RESULT) == 2){
            call(StarterFade)
            setvar(STARTER_LAB, 2)
        }
        elif (var(VAR_RESULT) == 3){
            call(StarterFade)
            setvar(STARTER_LAB, 3)
        }
        elif (var(VAR_RESULT) == 4){
            call(StarterFade)
            setvar(STARTER_LAB, 4)
        }
        elif (var(VAR_RESULT) == 5){
            call(StarterFade)
            setvar(STARTER_LAB, 5)
        }
        elif (var(VAR_RESULT) == 6){
            call(StarterFade)
            setvar(STARTER_LAB, 6)
        }
        elif (var(VAR_RESULT) == 7){
            call(StarterFade)
            setvar(STARTER_LAB, 7)
        }
        elif (var(VAR_RESULT) == 8){
            call(StarterFade)
            setvar(STARTER_LAB, 8)
        }
        msgbox("Choose wisely...")
        waitmessage
        release
   }else{
    msgbox("Take care of your Pokemon", MSGBOX_NPC)
   }
   end                     
}
 
script StarterFade{
    fadescreen(FADE_TO_BLACK)
    delay(20)
    fadescreen(FADE_FROM_BLACK)
    return
}
script LittlerootTown_StartersHuis_EventScript_PokeballOne{
    lockall
    if(!(flag(STARTER_GEN1) || flag(STARTER_GEN2) || flag(STARTER_GEN3) )){
        if(var(STARTER_LAB) == 0){
            call(LittlerootTown_StartersHuis_EventScript_Bulbasaur)
        }
        elif(var(STARTER_LAB) == 1){
            call(LittlerootTown_StartersHuis_EventScript_Chikorita)
        }
        elif(var(STARTER_LAB) == 2){
            call(LittlerootTown_StartersHuis_EventScript_Treecko)
        }
        elif(var(STARTER_LAB) == 3){
            call(LittlerootTown_StartersHuis_EventScript_Turtwig)
        }
        elif(var(STARTER_LAB) == 4){
            call(LittlerootTown_StartersHuis_EventScript_Snivy)
        }
        elif(var(STARTER_LAB) == 5){
            call(LittlerootTown_StartersHuis_EventScript_Chespin)
        }
        elif(var(STARTER_LAB) == 6){
            call(LittlerootTown_StartersHuis_EventScript_Rowlet)
        }
        elif(var(STARTER_LAB) == 7){
            call(LittlerootTown_StartersHuis_EventScript_Grookey)
        }
        elif(var(STARTER_LAB) == 8){
            call(LittlerootTown_StartersHuis_EventScript_Sprigatito)
        }
    }
    else{
        msgbox("Don't Take Another")
    }
    waitmessage
    releaseall
    end
}
 
